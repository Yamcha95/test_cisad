{% extends 'base.html.twig' %}

{% block title %}User index{% endblock %}

{% block body %}
<h1>Liste des Utilisateurs</h1>

    <div class="card bg-light mb-4 shadow-sm">
        <div class="card-body">
            <h5 class="card-title">Importer des utilisateurs via CSV</h5>
            {{ form_start(importForm) }}
                {{ form_widget(importForm) }}
            {{ form_end(importForm) }}
            <small class="text-muted">Format attendu : username, email, password</small>
        </div>
    </div>

    <table class="table table-striped mt-4">
    <table class="table">
        <thead>
            <tr>
                <th>Id</th>
                <th>Email</th>
                <th>Roles</th>
                <th>Password</th>
                <th>actions</th>
            </tr>
        </thead>
        <tbody>
        {% for user in users %}
            <tr>
                <td>{{ user.id }}</td>
                <td>{{ user.email }}</td>
                <td>{{ user.roles ? user.roles|json_encode : '' }}</td>
                <td>{{ user.password }}</td>
                <td>
                    <a href="{{ path('app_user_show', {'id': user.id}) }}">show</a>
                    <a href="{{ path('app_user_edit', {'id': user.id}) }}">edit</a>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="5">no records found</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

    <a href="{{ path('app_user_new') }}">Create new</a>
{% endblock %}
