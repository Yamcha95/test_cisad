{% extends 'base.html.twig' %}

{% block body %}
<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-primary text-white py-3">
                    <h5 class="mb-0 fw-bold">
                        <i class="bi bi-pencil-square me-2"></i>
                        {{ app.request.attributes.get('_route') == 'app_user_edit' ? 'Modifier l\'utilisateur' : 'Nouvel utilisateur' }}
                    </h5>
                </div>
                <div class="card-body p-4">
                    {{ form_start(form) }}
                        <div class="mb-3">
                            {{ form_label(form.username, 'Pseudo', {'label_attr': {'class': 'form-label fw-semibold'}}) }}
                            {{ form_widget(form.username, {'attr': {'class': 'form-control', 'placeholder': 'Ex: JeanDupont'}}) }}
                        </div>
                        <div class="mb-3">
                            {{ form_label(form.email, 'Adresse Email', {'label_attr': {'class': 'form-label fw-semibold'}}) }}
                            {{ form_widget(form.email, {'attr': {'class': 'form-control'}}) }}
                        </div>
                        <div class="mb-4">
                            {{ form_label(form.roles, 'Rôles', {'label_attr': {'class': 'form-label fw-semibold'}}) }}
                            {{ form_widget(form.roles, {'attr': {'class': 'form-select'}}) }}
                        </div>
                        
                        <div class="d-grid gap-2">
                            <button class="btn btn-primary">{{ button_label|default('Enregistrer les modifications') }}</button>
                            <a href="{{ path('app_user_index') }}" class="btn btn-link text-muted small">Annuler et revenir</a>
                        </div>
                    {{ form_end(form) }}
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}