{% extends 'base.html.twig' %}

{% block title %}Inscription{% endblock %}

{% block body %}
<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow border-0">
                <div class="card-header bg-primary text-white py-3">
                    <h1 class="h4 mb-0 fw-bold"><i class="bi bi-person-plus me-2"></i>Créer un compte</h1>
                </div>
                <div class="card-body p-4">
                    {# 1. LE NOVALIDATE EST CRUCIAL ICI #}
                    {{ form_start(registrationForm, {'attr': {'novalidate': 'novalidate'}}) }}
                        
                        <div class="mb-3">
                            {{ form_label(registrationForm.username, "Nom d'utilisateur", {'label_attr': {'class': 'form-label'}}) }}
                            {{ form_widget(registrationForm.username, {'attr': {'class': 'form-control'}}) }}
                            <div class="text-danger small">{{ form_errors(registrationForm.username) }}</div>
                        </div>

                        <div class="mb-3">
                            {{ form_label(registrationForm.email, "Email", {'label_attr': {'class': 'form-label'}}) }}
                            {{ form_widget(registrationForm.email, {'attr': {'class': 'form-control'}}) }}
                            <div class="text-danger small">{{ form_errors(registrationForm.email) }}</div>
                        </div>

                        <div class="mb-3">
                            {{ form_label(registrationForm.plainPassword, 'Mot de passe', {'label_attr': {'class': 'form-label fw-bold'}}) }}
                            {{ form_widget(registrationForm.plainPassword, {
                                'attr': {'class': 'form-control', 'placeholder': 'Ex: qwerty123'}
                            }) }}
                            {# 2. ON FORCE L'AFFICHAGE DE L'ERREUR ICI #}
                            <div class="alert alert-danger mt-2 py-1 px-2 small" style="{% if not form_errors(registrationForm.plainPassword) %}display:none;{% endif %}">
                                {{ form_errors(registrationForm.plainPassword) }}
                            </div>
                            <small class="text-muted">Minimum 8 caractères, incluant une lettre et un chiffre.</small>
                        </div>

                        <div class="mb-3">
                            {{ form_label(registrationForm.roles, 'Type de compte (Test Technique)', {'label_attr': {'class': 'fw-bold'}}) }}
                            <div class="p-3 border rounded bg-light">
                                {{ form_widget(registrationForm.roles) }}
                            </div>
                            <small class="text-muted">Choisissez "Administrateur" pour accéder aux fonctions d'import CSV.</small>
                        </div>

                        <div class="mb-3 form-check">
                            {{ form_widget(registrationForm.agreeTerms, { 'attr': {'class': 'form-check-input'} }) }}
                            {{ form_label(registrationForm.agreeTerms, 'Accepter les conditions', { 'label_attr': {'class': 'form-check-label'} }) }}
                            <div class="text-danger small">{{ form_errors(registrationForm.agreeTerms) }}</div>
                        </div>

                        <button type="submit" class="btn btn-primary btn-lg w-100 shadow-sm mt-3">
                            <i class="bi bi-check-lg"></i> S'inscrire
                        </button>
                    {{ form_end(registrationForm) }}
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}