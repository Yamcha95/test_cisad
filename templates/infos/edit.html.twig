{% extends 'base.html.twig' %}

{% block title %}Modifier les Statistiques{% endblock %}

{% block body %}
<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            {# Fil d'ariane / Retour #}
            <nav aria-label="breadcrumb" class="mb-4">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a href="{{ path('app_infos_index') }}">Statistiques</a></li>
                    <li class="breadcrumb-item active" aria-current="page">Modifier {{ info.user.username }}</li>
                </ol>
            </nav>

            <div class="card shadow-sm border-0">
                <div class="card-header bg-warning text-dark py-3">
                    <h1 class="h4 mb-0 fw-bold">
                        <i class="bi bi-pencil-square me-2"></i>Modifier les stats de : {{ info.user.username }}
                    </h1>
                </div>
                <div class="card-body p-4">
                    
                    {# Inclusion du formulaire avec un label de bouton personnalisé #}
                    {{ include('infos/_form.html.twig', {'button_label': 'Enregistrer les modifications'}) }}

                    <hr class="my-4">

                    <div class="d-flex justify-content-between align-items-center mt-3">
                        <a href="{{ path('app_infos_index') }}" class="btn btn-outline-secondary">
                            <i class="bi bi-arrow-left"></i> Retour à la liste
                        </a>
                        
                        {# Bouton de suppression (souvent dans un menu séparé ou en rouge discret) #}
                        <div class="text-end">
                            {{ include('infos/_delete_form.html.twig') }}
                        </div>
                    </div>
                </div>
            </div>
            
            {# Petit rappel du format pour l'admin #}
            <div class="mt-3 text-center">
                <small class="text-muted">
                    Dernière mise à jour : {{ "now"|date("d/m/Y H:i") }}
                </small>
            </div>
        </div>
    </div>
</div>
{% endblock %}