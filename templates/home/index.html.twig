{% extends 'base.html.twig' %}

{% block title %}Accueil - Test CISAD{% endblock %}

{% block body %}
<div class="p-5 mb-4 bg-light rounded-3 shadow-sm border">
    <div class="container-fluid py-5 text-center">
        <h1 class="display-5 fw-bold">Bienvenue sur le Test Technique CISAD</h1>
        <p class="col-md-12 fs-4 mt-3">
            Une application robuste développée avec <strong>Symfony 7</strong> et <strong>PHP 8.3</strong>.
        </p>
        <hr class="my-4">
        <p>Gestion des utilisateurs, import CSV massif et statistiques de jeu en temps réel.</p>
        
        <div class="d-grid gap-2 d-sm-flex justify-content-sm-center mt-4">
            <a href="{{ path('app_login') }}" class="btn btn-primary btn-lg px-4 gap-3">Se connecter</a>
            <a href="{{ path('app_register') }}" class="btn btn-outline-secondary btn-lg px-4">Créer un compte</a>
        </div>
    </div>
</div>

<div class="row g-4 py-5 row-cols-1 row-cols-lg-3">
    <div class="feature col text-center">
        <div class="feature-icon bg-primary bg-gradient text-white mb-2 rounded-3 p-2">🚀</div>
        <h2>Performance</h2>
        <p>Optimisé avec PHP 8.3 pour des réponses ultra-rapides.</p>
    </div>
    <div class="feature col text-center">
        <div class="feature-icon bg-success bg-gradient text-white mb-2 rounded-3 p-2">📊</div>
        <h2>Statistiques</h2>
        <p>Visualisation des rangs, victoires et défaites par profil.</p>
    </div>
    <div class="feature col text-center">
        <div class="feature-icon bg-warning bg-gradient text-white mb-2 rounded-3 p-2">📂</div>
        <h2>Import CSV</h2>
        <p>Outil d'administration pour importer des milliers d'utilisateurs.</p>
    </div>
</div>
{% endblock %}